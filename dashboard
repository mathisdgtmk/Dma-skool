<script>
  // Vérifie session
  const user = JSON.parse(sessionStorage.getItem('dma_user') || 'null');
  if (!user) { window.location.href = 'index.html'; }
  else {
    document.getElementById('welcomeName').textContent = user.name || '';
  }

  // Progress depuis localStorage
  const TOTAL = 28;
  function updateProgress() {
    let done = 0;
    for (let i = 1; i <= TOTAL; i++) {
      if (localStorage.getItem('module_' + i + '_done') === '1') {
        done++;
        const card = document.querySelector('[href="module-' + String(i).padStart(2,'0') + '.html"]');
        if (card) card.classList.add('completed');
      }
    }
    document.getElementById('progressCount').textContent = done + ' / ' + TOTAL;
    setTimeout(() => {
      document.getElementById('progressFill').style.width = (done / TOTAL * 100) + '%';
    }, 300);
  }
  updateProgress();

  function logout() {
    sessionStorage.removeItem('dma_user');
    window.location.href = 'index.html';
  }

  function scrollTop() {
    window.scrollTo({top:0, behavior:'smooth'});
  }
</script>


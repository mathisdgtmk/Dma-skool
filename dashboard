<!DOCTYPE html>

<html lang="fr">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no">
<title>DMA — Dashboard</title>
<style>
  @import url('https://fonts.googleapis.com/css2?family=Bebas+Neue&family=Cormorant+Garamond:ital,wght@0,300;0,400;1,300;1,400&family=Montserrat:wght@300;400;500;600&display=swap');

*{margin:0;padding:0;box-sizing:border-box;-webkit-tap-highlight-color:transparent}
html,body{height:100%;width:100%}

body{
background:#050505;
color:#f5f0e8;
font-family:‘Montserrat’,Arial,sans-serif;
min-height:100vh;
overflow-x:hidden;
}

/* BG */
body::before{
content:’’;position:fixed;inset:0;
background:
radial-gradient(ellipse 80% 40% at 50% 0%,rgba(192,0,26,.12) 0%,transparent 60%),
radial-gradient(ellipse 40% 30% at 0% 50%,rgba(201,168,76,.04) 0%,transparent 60%);
pointer-events:none;z-index:0;
}

/* HEADER */
.header{
position:sticky;top:0;z-index:50;
background:rgba(5,5,5,.92);
backdrop-filter:blur(12px);
-webkit-backdrop-filter:blur(12px);
border-bottom:1px solid rgba(201,168,76,.1);
padding:14px 20px;
display:flex;align-items:center;justify-content:space-between;
}

.header-logo{
display:flex;align-items:center;gap:10px;
}

.header-emblem{
width:34px;height:34px;
background:linear-gradient(135deg,#C0001A,#7a0010);
border-radius:50%;
display:flex;align-items:center;justify-content:center;
box-shadow:0 0 14px rgba(192,0,26,.4);
flex-shrink:0;
}
.header-emblem span{
font-family:‘Bebas Neue’,Impact,sans-serif;
font-size:11px;color:#C9A84C;letter-spacing:.5px;
}

.header-title{
font-family:‘Bebas Neue’,Impact,sans-serif;
font-size:18px;letter-spacing:3px;color:#f5f0e8;
}

.header-right{display:flex;align-items:center;gap:12px}

.welcome-name{
font-size:11px;font-weight:500;letter-spacing:1px;
color:rgba(201,168,76,.7);
display:none;
}
@media(min-width:400px){.welcome-name{display:block}}

.btn-logout{
background:none;border:1px solid rgba(201,168,76,.2);
border-radius:2px;padding:6px 12px;
color:rgba(245,240,232,.4);
font-family:‘Montserrat’,Arial,sans-serif;
font-size:9px;font-weight:600;letter-spacing:2px;
text-transform:uppercase;cursor:pointer;
transition:all .2s;-webkit-appearance:none;
}
.btn-logout:active{border-color:rgba(201,168,76,.5);color:#C9A84C}

/* MAIN */
.main{position:relative;z-index:1;padding:28px 16px 48px;}
@media(min-width:480px){.main{padding:32px 24px 60px;}}

/* HERO */
.hero{
text-align:center;
margin-bottom:36px;
animation:fadeUp .6s cubic-bezier(.16,1,.3,1) both;
}

.hero-tag{
display:inline-block;
font-size:9px;font-weight:600;letter-spacing:3px;
text-transform:uppercase;color:#C9A84C;
border:1px solid rgba(201,168,76,.2);
border-radius:20px;padding:5px 14px;
margin-bottom:14px;
background:rgba(201,168,76,.05);
}

.hero-title{
font-family:‘Bebas Neue’,Impact,sans-serif;
font-size:clamp(28px,7vw,48px);
letter-spacing:clamp(2px,1vw,5px);
color:#f5f0e8;line-height:1;
margin-bottom:10px;
}

.hero-title span{color:#C0001A}

.hero-sub{
font-family:‘Cormorant Garamond’,Georgia,serif;
font-size:clamp(13px,3vw,16px);
font-style:italic;
color:rgba(245,240,232,.45);
letter-spacing:1px;
margin-bottom:20px;
}

/* PROGRESS BAR */
.progress-wrap{
background:rgba(255,255,255,.04);
border:1px solid rgba(201,168,76,.1);
border-radius:3px;
padding:14px 16px;
margin-bottom:32px;
animation:fadeUp .6s .1s cubic-bezier(.16,1,.3,1) both;
}

.progress-top{
display:flex;justify-content:space-between;align-items:center;
margin-bottom:10px;
}

.progress-label{
font-size:9px;font-weight:600;letter-spacing:2.5px;
text-transform:uppercase;color:rgba(201,168,76,.6);
}

.progress-count{
font-family:‘Bebas Neue’,Impact,sans-serif;
font-size:16px;letter-spacing:2px;color:#C9A84C;
}

.progress-bar{
height:3px;background:rgba(255,255,255,.06);border-radius:2px;overflow:hidden;
}

.progress-fill{
height:100%;width:0%;
background:linear-gradient(90deg,#C0001A,#C9A84C);
border-radius:2px;
transition:width 1s cubic-bezier(.16,1,.3,1);
}

/* SECTION TITLE */
.section-title{
display:flex;align-items:center;gap:12px;
margin-bottom:16px;
}

.section-title-text{
font-family:‘Bebas Neue’,Impact,sans-serif;
font-size:13px;letter-spacing:3px;
color:rgba(245,240,232,.4);
text-transform:uppercase;
white-space:nowrap;
}

.section-title-line{
flex:1;height:1px;
background:linear-gradient(90deg,rgba(201,168,76,.15),transparent);
}

/* MODULE GRID */
.modules-grid{
display:grid;
grid-template-columns:1fr 1fr;
gap:10px;
margin-bottom:24px;
}
@media(min-width:480px){.modules-grid{gap:12px}}

/* MODULE CARD */
.module-card{
background:rgba(255,255,255,.03);
border:1px solid rgba(201,168,76,.08);
border-radius:4px;
padding:14px 12px;
cursor:pointer;
position:relative;
overflow:hidden;
transition:border-color .25s,background .25s,transform .15s;
animation:fadeUp .5s cubic-bezier(.16,1,.3,1) both;
text-decoration:none;
display:block;
}

.module-card::before{
content:’’;
position:absolute;inset:0;
background:linear-gradient(135deg,rgba(192,0,26,.06) 0%,transparent 60%);
opacity:0;transition:opacity .3s;
}

.module-card:active{
border-color:rgba(201,168,76,.3);
background:rgba(255,255,255,.05);
transform:scale(.98);
}
.module-card:active::before{opacity:1}

.module-card.completed{
border-color:rgba(201,168,76,.2);
background:rgba(201,168,76,.04);
}

.module-card.locked{
opacity:.45;cursor:default;
}

.module-num{
font-family:‘Bebas Neue’,Impact,sans-serif;
font-size:11px;letter-spacing:2px;
color:rgba(201,168,76,.4);
margin-bottom:6px;
display:block;
}

.module-title{
font-size:11px;font-weight:600;
letter-spacing:.3px;
color:#f5f0e8;
line-height:1.3;
margin-bottom:8px;
}

.module-card.locked .module-title{color:rgba(245,240,232,.4)}

.module-tag{
display:inline-block;
font-size:8px;font-weight:600;letter-spacing:1.5px;
text-transform:uppercase;
padding:3px 8px;border-radius:2px;
}

.tag-mindset{background:rgba(192,0,26,.15);color:#ff6b6b}
.tag-business{background:rgba(201,168,76,.12);color:#C9A84C}
.tag-content{background:rgba(100,180,255,.1);color:#7ab8ff}
.tag-tech{background:rgba(150,255,150,.08);color:#80d080}
.tag-premium{background:rgba(192,0,26,.2);color:#ff4444;border:1px solid rgba(192,0,26,.3)}

.module-check{
position:absolute;top:10px;right:10px;
width:18px;height:18px;
border:1px solid rgba(201,168,76,.2);
border-radius:50%;
display:flex;align-items:center;justify-content:center;
transition:all .2s;
}

.module-card.completed .module-check{
background:#C9A84C;
border-color:#C9A84C;
}

.module-check svg{width:9px;height:9px;stroke:#050505;fill:none;stroke-width:3;display:none}
.module-card.completed .module-check svg{display:block}

.module-lock{
position:absolute;top:10px;right:10px;
font-size:12px;opacity:.3;
}

/* BONUS SECTION */
.bonus-card{
background:linear-gradient(135deg,rgba(192,0,26,.08) 0%,rgba(201,168,76,.05) 100%);
border:1px solid rgba(192,0,26,.2);
border-radius:4px;
padding:16px;
display:flex;align-items:center;gap:14px;
cursor:pointer;
transition:border-color .2s,transform .15s;
text-decoration:none;
margin-bottom:10px;
animation:fadeUp .5s cubic-bezier(.16,1,.3,1) both;
}
.bonus-card:active{border-color:rgba(192,0,26,.5);transform:scale(.98)}

.bonus-icon{
width:40px;height:40px;flex-shrink:0;
background:linear-gradient(135deg,#C0001A,#7a0010);
border-radius:3px;
display:flex;align-items:center;justify-content:center;
font-size:18px;
}

.bonus-info{}
.bonus-label{
font-size:8px;font-weight:600;letter-spacing:2.5px;
text-transform:uppercase;color:#C9A84C;
margin-bottom:4px;display:block;
}
.bonus-title{font-size:13px;font-weight:600;color:#f5f0e8;line-height:1.2}

/* BOTTOM NAV */
.bottom-nav{
position:fixed;bottom:0;left:0;right:0;
background:rgba(5,5,5,.95);
backdrop-filter:blur(12px);
-webkit-backdrop-filter:blur(12px);
border-top:1px solid rgba(201,168,76,.08);
display:flex;z-index:50;
padding-bottom:env(safe-area-inset-bottom);
}

.nav-item{
flex:1;display:flex;flex-direction:column;
align-items:center;justify-content:center;
padding:10px 4px;
cursor:pointer;
border:none;background:none;
color:rgba(245,240,232,.25);
transition:color .2s;
-webkit-appearance:none;
font-family:‘Montserrat’,Arial,sans-serif;
}

.nav-item.active{color:#C9A84C}
.nav-item svg{width:20px;height:20px;margin-bottom:4px}
.nav-item span{font-size:8px;font-weight:600;letter-spacing:1.5px;text-transform:uppercase}

@keyframes fadeUp{
from{opacity:0;transform:translateY(16px)}
to{opacity:1;transform:translateY(0)}
}
</style>

</head>
